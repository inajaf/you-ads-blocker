<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
      Full-screen, no-ActionBar theme. Black window background matches the
      YouTube app so there is no flash of white while the WebView loads.
      The status/navigation bars are transparent because the Activity draws
      edge-to-edge (WindowCompat.setDecorFitsSystemWindows(false)).
    -->
    <style name="Theme.AdVoid" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

</resources>
