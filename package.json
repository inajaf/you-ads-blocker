{
  "name": "tubepwa",
  "private": true,
  "version": "2.0.0",
  "description": "YouTube-like ad-free PWA — no API keys. Piped + InnerTube via same-origin proxy.",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:local",
    "dev:local": "vite",
    "dev:ngrok": "node scripts/dev-ngrok.mjs",
    "dev:phone": "node scripts/dev-phone.mjs",
    "build": "tsc -b && vite build",
    "test": "node --experimental-strip-types --test tests/**/*.test.mjs",
    "preview": "vite preview",
    "build:extension": "node scripts/pack-extension.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "hls.js": "^1.6.16",
    "idb": "^8.0.3",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "qrcode": "^1.5.4",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
