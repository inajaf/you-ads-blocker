{
  "manifest_version": 3,
  "name": "Noirva Shield",
  "version": "1.3.5",
  "description": "Noirva filters known YouTube ad requests while you watch. No API keys.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "browsingData",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.youtube-nocookie.com/*",
    "*://*.youtu.be/*",
    "*://*.googlevideo.com/*",
    "*://*.google.com/*",
    "*://*.doubleclick.net/*",
    "*://*.googleadservices.com/*",
    "*://*.googlesyndication.com/*",
    "*://127.0.0.1/*",
    "*://localhost/*",
    "https://*.ngrok-free.app/*",
    "https://*.ngrok.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Noirva Shield",
    "default_icon": {
      "16": "icons/noirva-logo-v2-16.png",
      "48": "icons/noirva-logo-v2-48.png",
      "128": "icons/noirva-logo-v2-128.png"
    }
  },
  "icons": {
    "16": "icons/noirva-logo-v2-16.png",
    "48": "icons/noirva-logo-v2-48.png",
    "128": "icons/noirva-logo-v2-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/noirva-logo-v2-128.png"],
      "matches": [
        "*://*.youtube.com/*",
        "*://*.youtube-nocookie.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.youtube-nocookie.com/*"
      ],
      "js": ["maintenance.js", "desktop-guide.js", "desktop-guide-ui.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.youtube-nocookie.com/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "*://accounts.google.com/*",
        "*://myaccount.google.com/*"
      ],
      "js": ["account-back.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://127.0.0.1/*",
        "http://localhost/*",
        "https://*.ngrok-free.app/*",
        "https://*.ngrok.app/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "youtube_ads",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
